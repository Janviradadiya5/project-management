# ============================================================================
# Django Core Settings
# ============================================================================
DJANGO_ENV=development
DEBUG=True
SECRET_KEY=change-me-in-production-min-50-chars-recommended-for-security
ALLOWED_HOSTS=localhost,127.0.0.1,*.example.com
ENVIRONMENT=development
APP_BASE_URL=http://127.0.0.1:8000

# ============================================================================
# Database Configuration
# ============================================================================
DB_NAME=app
DB_USER=app
DB_PASSWORD=app
DB_HOST=db
DB_PORT=5432
DB_SSLMODE=prefer
DB_CONN_MAX_AGE=60
DB_ATOMIC_REQUESTS=True
DB_CONNECT_TIMEOUT=10

# Alternative: PostgreSQL single connection string
# DATABASE_URL=postgresql://app:app@db:5432/app

# ============================================================================
# Redis / Cache Configuration
# ============================================================================
REDIS_URL=redis://:redis_password@redis:6379/0
REDIS_PASSWORD=redis_password
CACHE_TIMEOUT=300

# ============================================================================
# Security Settings
# ============================================================================
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
CSRF_TRUSTED_ORIGINS=
CSRF_COOKIE_HTTPONLY=True
SESSION_COOKIE_HTTPONLY=True

# ============================================================================
# CORS & API Settings
# ============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=True
API_VERSION=v1
API_RATE_LIMIT=1000

# ============================================================================
# Email Configuration
# ============================================================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@example.com
SUPPORT_EMAIL=support@example.com

# Free option (recommended): Brevo SMTP free tier (~300 emails/day)
# 1) Create account at brevo.com
# 2) Create SMTP key, then switch EMAIL_BACKEND to SMTP below
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp-relay.brevo.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-brevo-login
# EMAIL_HOST_PASSWORD=your-brevo-smtp-key

# Alternative (Gmail SMTP)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# ============================================================================
# Authentication & Authorization
# ============================================================================
JWT_ALGORITHM=HS256
JWT_AUTH_HEADER_PREFIX=Bearer
JWT_ACCESS_TOKEN_EXPIRE_HOURS=24
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=True
PASSWORD_REQUIRE_LOWERCASE=True
PASSWORD_REQUIRE_DIGITS=True
PASSWORD_REQUIRE_SPECIAL_CHARS=True

# ============================================================================
# File Storage Configuration
# ============================================================================
# Local storage (development)
DEFAULT_FILE_STORAGE=django.core.files.storage.FileSystemStorage
MEDIA_URL=/media/
MEDIA_ROOT=/app/media

# Static files
STATIC_URL=/static/
STATIC_ROOT=/app/staticfiles

# AWS S3 Configuration (for production)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=
AWS_LOCATION=

# ============================================================================
# Logging & Observability
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/app/logs/django.log
SENTRY_DSN=
DATADOG_API_KEY=
NEWRELIC_LICENSE_KEY=

# ============================================================================
# File Upload Settings
# ============================================================================
FILE_UPLOAD_MAX_MEMORY_SIZE=5242880
DATA_UPLOAD_MAX_MEMORY_SIZE=5242880
ALLOWED_FILE_EXTENSIONS=pdf,doc,docx,xls,xlsx,jpg,jpeg,png,gif,txt
MAX_FILE_SIZE_MB=10

# ============================================================================
# Celery Configuration (Async Tasks)
# ============================================================================
CELERY_BROKER_URL=redis://:redis_password@redis:6379/1
CELERY_RESULT_BACKEND=redis://:redis_password@redis:6379/1
CELERY_BROKER_URL=redis://:redis_password@redis:6379/1
CELERY_RESULT_BACKEND=redis://:redis_password@redis:6379/2
CELERY_ACCEPT_CONTENT=json
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_TIMEZONE=UTC
CELERY_TASK_TRACK_STARTED=True
CELERY_TASK_TIMEOUT=3600

# ============================================================================
# Application-Specific Settings
# ============================================================================
# Organization
DEFAULT_ORG_NAME=My Organization
DEFAULT_ORG_TIMEZONE=UTC

# Projects
PROJECT_ACTIVITY_LOG_RETENTION_DAYS=365
PROJECT_SOFT_DELETE_RETENTION_DAYS=30

# Notifications
EMAIL_ON_NOTIFICATION=True
NOTIFICATION_DIGEST_FREQUENCY=daily
MAX_CONCURRENT_NOTIFICATIONS=100

# Webhooks
WEBHOOK_TIMEOUT_SECONDS=30
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAY_SECONDS=60

# ============================================================================
# Third-Party Integrations
# ============================================================================
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
GITHUB_API_TOKEN=
SLACK_BOT_TOKEN=
SLACK_WEBHOOK_URL=

# ============================================================================
# Development Tools & Testing
# ============================================================================
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin_password_123
ENABLE_DEBUG_TOOLBAR=True
ENABLE_SILK_PROFILER=False
RUN_MIGRATIONS_ON_STARTUP=True

# ============================================================================
# Monitoring & Alarms
# ============================================================================
HEALTH_CHECK_ENABLED=True
HEALTHCHECK_URL=/health/
ALERT_EMAIL=ops@example.com
ALERT_SLACK_CHANNEL=#alerts

# ============================================================================
# Feature Flags
# ============================================================================
FEATURE_EMAIL_VERIFICATION=True
FEATURE_TWO_FACTOR_AUTH=False
FEATURE_ACTIVITY_LOGGING=True
FEATURE_WEBHOOKS=True
FEATURE_ASYNC_PROCESSING=True

# ============================================================================
# Performance & Caching
# ============================================================================
CACHE_CONTROL_MAX_AGE=3600
PAGE_SIZE_DEFAULT=20
PAGE_SIZE_MAX=100
QUERY_TIMEOUT_SECONDS=30

