# Copy this file to .env.production and replace every placeholder before deploy.

DJANGO_ENV=production
ENVIRONMENT=production
SECRET_KEY=replace-with-a-long-random-secret
ALLOWED_HOSTS=api.example.com,app.example.com
CORS_ALLOWED_ORIGINS=https://app.example.com
CSRF_TRUSTED_ORIGINS=https://api.example.com,https://app.example.com

DB_NAME=app
DB_USER=app
DB_PASSWORD=replace-db-password
DB_HOST=db
DB_PORT=5432
DB_SSLMODE=require
DB_CONN_MAX_AGE=300
DB_ATOMIC_REQUESTS=True
DB_CONNECT_TIMEOUT=10

REDIS_PASSWORD=replace-redis-password

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=noreply@example.com
SERVER_EMAIL=noreply@example.com
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_HOST_USER=replace-smtp-user
EMAIL_HOST_PASSWORD=replace-smtp-password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=10

LOG_LEVEL=INFO
LOG_FORMAT=json
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.0

# Optional. Leave blank to use the same origin that serves the frontend.
VITE_API_BASE_URL=